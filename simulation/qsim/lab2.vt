		$display ("ERROR! Vector Mismatch for output port Qout[27] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qout_expected_prev);
		$display ("     Real value = %b", Qout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qout_exp[27] = Qout_expected_prev[27];
	end
	if (
		( Qout_expected_prev[28] !== 1'bx ) && ( Qout_prev[28] !== Qout_expected_prev[28] )
		&& ((Qout_expected_prev[28] !== last_Qout_exp[28]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qout[28] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qout_expected_prev);
		$display ("     Real value = %b", Qout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qout_exp[28] = Qout_expected_prev[28];
	end
	if (
		( Qout_expected_prev[29] !== 1'bx ) && ( Qout_prev[29] !== Qout_expected_prev[29] )
		&& ((Qout_expected_prev[29] !== last_Qout_exp[29]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qout[29] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qout_expected_prev);
		$display ("     Real value = %b", Qout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qout_exp[29] = Qout_expected_prev[29];
	end
	if (
		( Qout_expected_prev[30] !== 1'bx ) && ( Qout_prev[30] !== Qout_expected_prev[30] )
		&& ((Qout_expected_prev[30] !== last_Qout_exp[30]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qout[30] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qout_expected_prev);
		$display ("     Real value = %b", Qout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qout_exp[30] = Qout_expected_prev[30];
	end
	if (
		( Qout_expected_prev[31] !== 1'bx ) && ( Qout_prev[31] !== Qout_expected_prev[31] )
		&& ((Qout_expected_prev[31] !== last_Qout_exp[31]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Qout[31] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Qout_expected_prev);
		$display ("     Real value = %b", Qout_prev);
		nummismatches = nummismatches + 1;
		on_first_change[1] = 1'b0;
		last_Qout_exp[31] = Qout_expected_prev[31];
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module PC_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clk;
reg load;
reg [31:0] Qin;
// wires                                               
wire [31:0] Qout;

wire sampler;                             

// assign statements (if any)                          
PC i1 (
// port map - connection between master ports and signals/registers   
	.clk(clk),
	.load(load),
	.Qin(Qin),
	.Qout(Qout)
);

// clk
always
begin
	clk = 1'b0;
	clk = #5000 1'b1;
	#5000;
end 

// load
initial
begin
	load = 1'b0;
	load = #20000 1'b1;
	load = #10000 1'b0;
	load = #210000 1'b1;
